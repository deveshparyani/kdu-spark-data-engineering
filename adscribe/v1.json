{
  "pipeline": {
    "name": "adscribe",
    "schema_version": "v1"
  },
  "client": {
    "id": "adscribe",
    "description": "Adscribe daily export normalized into the shared warehouse schema with impressions and campaign metadata."
  },
  "source_format": "csv",
  "partition_column": "date",
  "date_column": "date",
  "rename_columns": {
    "report_date": "report_date_raw",
    "created_at": "created_at_raw",
    "period_start": "period_start_raw",
    "client_name": "client_name",
    "show_name": "show",
    "revenue": "revenue_raw",
    "orders": "orders_raw",
    "impressions": "impressions_raw",
    "discount_code": "discount_code",
    "campaign_name": "campaign_name",
    "campaign_item_id": "campaign_item_id"
  },
  "cleaning_rules": {
    "discount_code": "uppercase"
  },
  "joins": [],
  "transformations": {
    "cast_columns": {},
    "fill_nulls": {},
    "derived_columns": [
      {
        "name": "date",
        "expression": "COALESCE(to_date(report_date_raw, 'yyyy-MM-dd'), to_date(period_start_raw, 'MM/dd/yyyy'), to_date(report_date_raw))"
      },
      {
        "name": "revenue",
        "expression": "CASE WHEN revenue_raw IS NULL OR trim(revenue_raw) IN ('', '-') THEN NULL ELSE CAST(regexp_replace(trim(revenue_raw), '[^0-9.\\\\-]', '') AS DOUBLE) END"
      },
      {
        "name": "orders",
        "expression": "CASE WHEN orders_raw IS NULL OR trim(orders_raw) = '' THEN NULL ELSE CAST(regexp_replace(trim(orders_raw), '[^0-9\\\\-]', '') AS DOUBLE) END"
      },
      {
        "name": "impressions",
        "expression": "CASE WHEN impressions_raw IS NULL OR trim(impressions_raw) = '' THEN NULL ELSE CAST(regexp_replace(trim(impressions_raw), '[^0-9\\\\-]', '') AS DOUBLE) END"
      },
      {
        "name": "revenue_per_order",
        "expression": "CASE WHEN orders_raw IS NULL OR trim(orders_raw) = '' OR CAST(regexp_replace(trim(orders_raw), '[^0-9\\\\-]', '') AS DOUBLE) = 0 THEN NULL ELSE CAST(regexp_replace(trim(revenue_raw), '[^0-9.\\\\-]', '') AS DOUBLE) / CAST(regexp_replace(trim(orders_raw), '[^0-9\\\\-]', '') AS DOUBLE) END"
      },
      {
        "name": "revenue_per_impression",
        "expression": "CASE WHEN impressions_raw IS NULL OR trim(impressions_raw) = '' OR CAST(regexp_replace(trim(impressions_raw), '[^0-9\\\\-]', '') AS DOUBLE) = 0 THEN NULL ELSE CAST(regexp_replace(trim(revenue_raw), '[^0-9.\\\\-]', '') AS DOUBLE) / CAST(regexp_replace(trim(impressions_raw), '[^0-9\\\\-]', '') AS DOUBLE) END"
      },
      {
        "name": "impressions_per_order",
        "expression": "CASE WHEN orders_raw IS NULL OR trim(orders_raw) = '' OR CAST(regexp_replace(trim(orders_raw), '[^0-9\\\\-]', '') AS DOUBLE) = 0 THEN NULL ELSE CAST(regexp_replace(trim(impressions_raw), '[^0-9\\\\-]', '') AS DOUBLE) / CAST(regexp_replace(trim(orders_raw), '[^0-9\\\\-]', '') AS DOUBLE) END"
      },
      {
        "name": "client_id",
        "expression": "'adscribe'"
      }
    ],
    "filter_expressions": [
      "date IS NOT NULL",
      "discount_code IS NOT NULL"
    ]
  },
  "drop_columns": [],
  "gold_aggregations": {
    "group_by": [
      "date",
      "discount_code",
      "show",
      "campaign_name",
      "campaign_item_id",
      "client_name"
    ],
    "metrics": [
      {
        "column": "orders",
        "function": "sum",
        "alias": "orders"
      },
      {
        "column": "revenue",
        "function": "sum",
        "alias": "revenue"
      },
      {
        "column": "impressions",
        "function": "sum",
        "alias": "impressions"
      }
    ]
  },
  "common_cleaning": {
    "date_parsing_rules": {
      "target_column": "date",
      "accepted_formats": [
        "yyyy-MM-dd",
        "MM/dd/yyyy"
      ]
    },
    "numeric_cleaning": {
      "target_columns": [
        "revenue_raw",
        "orders_raw",
        "impressions_raw"
      ],
      "remove_currency_symbols": true,
      "remove_thousands_separators": true,
      "normalize_decimal_separator": "."
    },
    "text_normalization": {
      "trim_columns": [
        "discount_code",
        "show"
      ],
      "uppercase_columns": [
        "discount_code"
      ]
    },
    "missing_value_strategy": {
      "drop_rows_when_missing": [
        "report_date_raw",
        "discount_code"
      ]
    }
  },
  "quarantine_rules": [],
  "post_processing": {
    "column_renaming": {
      "date": "date",
      "revenue": "revenue",
      "orders": "orders",
      "impressions": "impressions",
      "revenue_per_order": "revenue_per_order",
      "revenue_per_impression": "revenue_per_impression",
      "impressions_per_order": "impressions_per_order",
      "discount_code": "discount_code",
      "show": "show",
      "campaign_name": "campaign_name",
      "campaign_item_id": "campaign_item_id",
      "client_name": "client_name",
      "client_id": "client_id"
    },
    "sorting_rules": [
      {
        "column": "date",
        "direction": "asc"
      },
      {
        "column": "discount_code",
        "direction": "asc"
      },
      {
        "column": "show",
        "direction": "asc"
      }
    ],
    "filtering_rules": [
      "discount_code IS NOT NULL"
    ]
  },
  "outputs": {
    "loaded_path": "s3://kdu-spark-s3-data-lake-dev-743298171118/processed/client=adscribe/",
    "quarantine_path": "s3://kdu-spark-s3-data-lake-dev-743298171118/quarantine/client=adscribe/",
    "loaded_schema": [
      {
        "name": "date",
        "type": "date"
      },
      {
        "name": "discount_code",
        "type": "string"
      },
      {
        "name": "orders",
        "type": "double"
      },
      {
        "name": "revenue",
        "type": "double"
      },
      {
        "name": "impressions",
        "type": "double"
      },
      {
        "name": "revenue_per_order",
        "type": "double"
      },
      {
        "name": "revenue_per_impression",
        "type": "double"
      },
      {
        "name": "impressions_per_order",
        "type": "double"
      },
      {
        "name": "show",
        "type": "string"
      },
      {
        "name": "campaign_name",
        "type": "string"
      },
      {
        "name": "campaign_item_id",
        "type": "string"
      },
      {
        "name": "client_name",
        "type": "string"
      },
      {
        "name": "client_id",
        "type": "string"
      }
    ],
    "quarantine_schema": [
      {
        "name": "report_date_raw",
        "type": "string"
      },
      {
        "name": "show",
        "type": "string"
      },
      {
        "name": "discount_code",
        "type": "string"
      },
      {
        "name": "revenue_raw",
        "type": "string"
      },
      {
        "name": "orders_raw",
        "type": "string"
      },
      {
        "name": "impressions_raw",
        "type": "string"
      },
      {
        "name": "quarantine_reason",
        "type": "string"
      }
    ]
  }
}
